// ============================================================
//  config.h.example
//  このファイルを「config.h」という名前でコピーして、
//  ご自身の環境に合わせて書き換えてください。
//  ※ config.h は .gitignore に登録されているため、
//    誤ってGitHubに公開される心配はありません。
// ============================================================
#pragma once

// ---------- WiFi設定 ----------
// ご自宅のWiFiのSSIDとパスワードを記入してください
// ※ M5StickC Plusは2.4GHz帯のWiFiのみ対応です(5GHz帯には接続できません)
#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

// ---------- IFTTT設定 ----------
// IFTTTのWebhooksで発行されたキーを記入してください
// (取得方法はREADMEの「IFTTTの設定」を参照)
#define IFTTT_KEY "your-ifttt-webhooks-key"

// IFTTTで作成したイベント名(READMEの手順どおりに作成した場合は変更不要)
#define EVENT_ALIVE "AliveMonitoring" // 一定時間動きが無いときに送る通知
#define EVENT_DETECT "DetectEvent"    // 動きを再検出したときに送る通知

// ---------- 監視設定 ----------
// 設置場所の名前(通知メッセージに含まれます。日本語OK)
#define PLACE_NAME "トイレ"

// 何秒間動きが検出されなかったら通知するか
// 86400秒 = 24時間(1日)
#define LIMIT_TIME_SEC 86400
